{
  "name": "nuxt-vant-mobile",
  "type": "module",
  "version": "0.6.0",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "commitlint": "commitlint --edit",
    "typecheck": "nuxi typecheck",
    "release": "bumpp --commit --push --tag"
  },
  "dependencies": {
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/i18n": "^10.4.0",
    "nuxt": "^4.4.8",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@iconify-json/carbon": "^1.2.23",
    "@nuxt/eslint": "^1.16.0",
    "@pinia/nuxt": "^0.11.3",
    "@unocss/eslint-plugin": "66.7.2",
    "@unocss/nuxt": "66.7.2",
    "@vant/nuxt": "^1.0.7",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.8",
    "pinia": "^3.0.4",
    "postcss-mobile-forever": "^5.0.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vant": "^4.9.24",
    "vue-tsc": "^3.3.5"
  },
  "resolutions": {
    "vite": "^8.0.16"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint $1"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "browserslist": [
    "defaults"
  ]
}
